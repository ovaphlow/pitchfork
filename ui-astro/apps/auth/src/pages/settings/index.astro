---
import DashboardLayout from "../../layouts/DashboardLayout.astro";
---

<DashboardLayout title="系统设置" active="settings">
  <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
    <a href="/settings/users" class="block rounded-lg border border-border bg-surface p-6 hover:bg-surface-alt transition-colors no-underline">
      <div class="w-10 h-10 rounded-lg bg-accent-subtle flex items-center justify-center mb-4">
        <svg class="w-5 h-5 text-accent" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/>
        </svg>
      </div>
      <h3 class="text-sm font-semibold text-fg mb-1">用户管理</h3>
      <p class="text-xs text-fg-dimmed">管理系统用户账号、状态和权限</p>
    </a>
    <a href="/settings/departments" class="block rounded-lg border border-border bg-surface p-6 hover:bg-surface-alt transition-colors no-underline">
      <div class="w-10 h-10 rounded-lg bg-accent-subtle flex items-center justify-center mb-4">
        <svg class="w-5 h-5 text-accent" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/>
        </svg>
      </div>
      <h3 class="text-sm font-semibold text-fg mb-1">部门管理</h3>
      <p class="text-xs text-fg-dimmed">管理组织架构和部门信息</p>
    </a>
  </div>
</DashboardLayout>
