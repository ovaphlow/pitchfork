    <span class="text-5xl mb-4">🏭</span>
    <h2 class="text-xl font-semibold text-fg-emphasis mb-2">培训管理系统</h2>
    <p class="text-sm text-fg-dimmed mb-6">知识管理 · 培训考核 · 技能认证</p>
    <a href="/dashboard" class="inline-flex items-center justify-center h-10 px-6 rounded-md bg-accent text-white text-sm font-medium no-underline transition-all hover:brightness-110">
      进入仪表盘
    </a>
  </div>
</AdminLayout>
