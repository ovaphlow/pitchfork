---
import "../styles/global.css";

interface Props {
  title: string;
  active?:
    | "dashboard"
    | "knowledge"
    | "knowledge-editor"
    | "knowledge-approvals"
    | "courses"
    | "courses-editor"
    | "exams"
    | "questions"
    | "skills"
    | "positions"
    | "employees"
    | "departments"
    | "training-tasks"
    | "analytics";
}

const { title, active } = Astro.props;

function isActive(name: string) {
  return active === name;
}
---

<!doctype html>
<html lang="zh-CN" class="dark h-full">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title} — 培训管理系统</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  </head>
  <body class="h-full bg-bg text-fg antialiased overflow-hidden font-body">
    <div class="flex h-full" id="app-shell">
      <!-- ====== Sidebar ====== -->
      <aside
        id="sidebar"
        class="flex flex-col bg-surface border-r border-border overflow-hidden z-10 transition-all duration-250 ease-in-out"
        style="width: var(--sidebar-w); min-width: var(--sidebar-w)"
      >
        <!-- Header -->
        <div class="flex items-center gap-3 h-[var(--topbar-h)] px-4 border-b border-border shrink-0">
          <div class="w-8 h-8 shrink-0 rounded-sm flex items-center justify-center"
               style="background: linear-gradient(135deg, var(--color-accent), oklch(52% 0.14 210))">
            <svg class="w-[18px] h-[18px] text-white" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M4 19.5A2.5 2.5 0 0 1 6.5 17H20"/>
              <path d="M6.5 2H20v20H6.5A2.5 2.5 0 0 1 4 19.5v-15A2.5 2.5 0 0 1 6.5 2z"/>
            </svg>
          </div>
          <span class="text-sm font-semibold text-fg-emphasis whitespace-nowrap overflow-hidden sidebar-label">培训管理系统</span>
        </div>

        <!-- Nav -->
        <nav class="flex-1 overflow-y-auto p-3 flex flex-col gap-0.5">
          <div class="text-xs font-semibold text-fg-dimmed uppercase tracking-widest px-3 py-3 pb-1 whitespace-nowrap overflow-hidden sidebar-section">总览</div>

          <!-- 仪表盘 -->
          <a href="/dashboard" class={"flex items-center gap-3 h-10 px-3 rounded-md text-sm no-underline cursor-pointer whitespace-nowrap overflow-hidden transition-all duration-150 " + (isActive("dashboard") ? "bg-accent-subtle text-accent font-medium" : "text-fg-muted hover:bg-surface-alt hover:text-fg")}>
            <svg class="w-[18px] h-[18px] shrink-0 opacity-70" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <rect x="3" y="3" width="7" height="7"/><rect x="14" y="3" width="7" height="7"/><rect x="3" y="14" width="7" height="7"/><rect x="14" y="14" width="7" height="7"/>
            </svg>
            <span class="overflow-hidden sidebar-label">仪表盘</span>
          </a>

          <div class="text-xs font-semibold text-fg-dimmed uppercase tracking-widest px-3 py-3 pb-1 whitespace-nowrap overflow-hidden sidebar-section">知识管理</div>

          <!-- 知识库 -->
          <a href="/knowledge" class={"flex items-center gap-3 h-10 px-3 rounded-md text-sm no-underline cursor-pointer whitespace-nowrap overflow-hidden transition-all duration-150 " + (isActive("knowledge") ? "bg-accent-subtle text-accent font-medium" : "text-fg-muted hover:bg-surface-alt hover:text-fg")}>
            <svg class="w-[18px] h-[18px] shrink-0 opacity-70" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M4 19.5A2.5 2.5 0 0 1 6.5 17H20"/>
              <path d="M6.5 2H20v20H6.5A2.5 2.5 0 0 1 4 19.5v-15A2.5 2.5 0 0 1 6.5 2z"/>
            </svg>
            <span class="overflow-hidden sidebar-label">知识库</span>
          </a>

          <!-- 知识审批 -->
          <a href="/knowledge/approvals" class={"flex items-center gap-3 h-10 px-3 rounded-md text-sm no-underline cursor-pointer whitespace-nowrap overflow-hidden transition-all duration-150 " + (isActive("knowledge-approvals") ? "bg-accent-subtle text-accent font-medium" : "text-fg-muted hover:bg-surface-alt hover:text-fg")}>
            <svg class="w-[18px] h-[18px] shrink-0 opacity-70" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M9 12l2 2 4-4"/><path d="M12 2a10 10 0 1 0 0 20 10 10 0 0 0 0-20z"/>
            </svg>
            <span class="overflow-hidden sidebar-label">知识审批</span>
          </a>

          <div class="text-xs font-semibold text-fg-dimmed uppercase tracking-widest px-3 py-3 pb-1 whitespace-nowrap overflow-hidden sidebar-section">培训管理</div>

          <!-- 课程 -->
          <a href="/courses" class={"flex items-center gap-3 h-10 px-3 rounded-md text-sm no-underline cursor-pointer whitespace-nowrap overflow-hidden transition-all duration-150 " + (isActive("courses") ? "bg-accent-subtle text-accent font-medium" : "text-fg-muted hover:bg-surface-alt hover:text-fg")}>
            <svg class="w-[18px] h-[18px] shrink-0 opacity-70" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M22 10v6M2 10l10-5 10 5-10 5z"/>
              <path d="M6 12v5c3 3 9 3 12 0v-5"/>
            </svg>
            <span class="overflow-hidden sidebar-label">课程管理</span>
          </a>

          <!-- 培训任务 -->
          <a href="/training-tasks" class={"flex items-center gap-3 h-10 px-3 rounded-md text-sm no-underline cursor-pointer whitespace-nowrap overflow-hidden transition-all duration-150 " + (isActive("training-tasks") ? "bg-accent-subtle text-accent font-medium" : "text-fg-muted hover:bg-surface-alt hover:text-fg")}>
            <svg class="w-[18px] h-[18px] shrink-0 opacity-70" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M9 11l3 3L22 4"/><path d="M21 12v7a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11"/>
            </svg>
            <span class="overflow-hidden sidebar-label">培训任务</span>
          </a>

          <!-- 考试 -->
          <a href="/exams" class={"flex items-center gap-3 h-10 px-3 rounded-md text-sm no-underline cursor-pointer whitespace-nowrap overflow-hidden transition-all duration-150 " + (isActive("exams") ? "bg-accent-subtle text-accent font-medium" : "text-fg-muted hover:bg-surface-alt hover:text-fg")}>
            <svg class="w-[18px] h-[18px] shrink-0 opacity-70" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/>
              <polyline points="14 2 14 8 20 8"/>
              <line x1="16" y1="13" x2="8" y2="13"/>
              <line x1="16" y1="17" x2="8" y2="17"/>
            </svg>
            <span class="overflow-hidden sidebar-label">试卷管理</span>
          </a>

          <!-- 题库 -->
          <a href="/questions" class={"flex items-center gap-3 h-10 px-3 rounded-md text-sm no-underline cursor-pointer whitespace-nowrap overflow-hidden transition-all duration-150 " + (isActive("questions") ? "bg-accent-subtle text-accent font-medium" : "text-fg-muted hover:bg-surface-alt hover:text-fg")}>
            <svg class="w-[18px] h-[18px] shrink-0 opacity-70" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <circle cx="12" cy="12" r="10"/>
              <path d="M9.09 9a3 3 0 0 1 5.83 1c0 2-3 3-3 3"/>
              <line x1="12" y1="17" x2="12.01" y2="17"/>
            </svg>
            <span class="overflow-hidden sidebar-label">题库</span>
          </a>

          <div class="text-xs font-semibold text-fg-dimmed uppercase tracking-widest px-3 py-3 pb-1 whitespace-nowrap overflow-hidden sidebar-section">技能管理</div>

          <!-- 技能矩阵 -->
          <a href="/skills" class={"flex items-center gap-3 h-10 px-3 rounded-md text-sm no-underline cursor-pointer whitespace-nowrap overflow-hidden transition-all duration-150 " + (isActive("skills") ? "bg-accent-subtle text-accent font-medium" : "text-fg-muted hover:bg-surface-alt hover:text-fg")}>
            <svg class="w-[18px] h-[18px] shrink-0 opacity-70" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M12 20h9"/><path d="M16.5 3.5a2.121 2.121 0 0 1 3 3L7 19l-4 1 1-4L16.5 3.5z"/>
            </svg>
            <span class="overflow-hidden sidebar-label">技能矩阵</span>
          </a>

          <!-- 岗位 -->
          <a href="/positions" class={"flex items-center gap-3 h-10 px-3 rounded-md text-sm no-underline cursor-pointer whitespace-nowrap overflow-hidden transition-all duration-150 " + (isActive("positions") ? "bg-accent-subtle text-accent font-medium" : "text-fg-muted hover:bg-surface-alt hover:text-fg")}>
            <svg class="w-[18px] h-[18px] shrink-0 opacity-70" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/>
              <polyline points="9 22 9 12 15 12 15 22"/>
            </svg>
            <span class="overflow-hidden sidebar-label">岗位定义</span>
          </a>

          <!-- 员工管理 -->
          <a href="/employees" class={"flex items-center gap-3 h-10 px-3 rounded-md text-sm no-underline cursor-pointer whitespace-nowrap overflow-hidden transition-all duration-150 " + (isActive("employees") ? "bg-accent-subtle text-accent font-medium" : "text-fg-muted hover:bg-surface-alt hover:text-fg")}>
            <svg class="w-[18px] h-[18px] shrink-0 opacity-70" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/>
            </svg>
            <span class="overflow-hidden sidebar-label">员工管理</span>
          </a>

          <!-- 部门管理 -->
          <a href="/departments" class={"flex items-center gap-3 h-10 px-3 rounded-md text-sm no-underline cursor-pointer whitespace-nowrap overflow-hidden transition-all duration-150 " + (isActive("departments") ? "bg-accent-subtle text-accent font-medium" : "text-fg-muted hover:bg-surface-alt hover:text-fg")}>
            <svg class="w-[18px] h-[18px] shrink-0 opacity-70" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/>
            </svg>
            <span class="overflow-hidden sidebar-label">部门管理</span>
          </a>

          <div class="text-xs font-semibold text-fg-dimmed uppercase tracking-widest px-3 py-3 pb-1 whitespace-nowrap overflow-hidden sidebar-section">数据分析</div>

          <!-- 分析 -->
          <a href="/analytics" class={"flex items-center gap-3 h-10 px-3 rounded-md text-sm no-underline cursor-pointer whitespace-nowrap overflow-hidden transition-all duration-150 " + (isActive("analytics") ? "bg-accent-subtle text-accent font-medium" : "text-fg-muted hover:bg-surface-alt hover:text-fg")}>
            <svg class="w-[18px] h-[18px] shrink-0 opacity-70" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <line x1="18" y1="20" x2="18" y2="10"/><line x1="12" y1="20" x2="12" y2="4"/><line x1="6" y1="20" x2="6" y2="14"/>
            </svg>
            <span class="overflow-hidden sidebar-label">数据分析</span>
          </a>
        </nav>

        <!-- Footer -->
        <div class="border-t border-border p-3 shrink-0">
          <a href="/login" class="flex items-center gap-3 h-10 px-3 rounded-md text-sm no-underline cursor-pointer whitespace-nowrap overflow-hidden transition-all duration-150 text-fg-dimmed hover:bg-surface-alt hover:text-fg">
            <svg class="w-[18px] h-[18px] shrink-0 opacity-70" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"/><polyline points="16 17 21 12 16 7"/><line x1="21" y1="12" x2="9" y2="12"/>
            </svg>
            <span class="overflow-hidden sidebar-label">退出登录</span>
          </a>
        </div>
      </aside>

      <!-- ====== Main ====== -->
      <main class="flex-1 flex flex-col overflow-hidden min-w-0">
        <!-- Topbar -->
        <header class="flex items-center justify-between h-[var(--topbar-h)] px-6 bg-surface border-b border-border shrink-0">
          <div class="flex items-center gap-3">
            <button id="sidebar-toggle" class="w-9 h-9 flex items-center justify-center bg-transparent border border-border rounded-sm text-fg-muted hover:bg-surface-alt hover:text-fg cursor-pointer transition-all duration-150">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round">
                <line x1="3" y1="6" x2="21" y2="6"/><line x1="3" y1="12" x2="15" y2="12"/><line x1="3" y1="18" x2="21" y2="18"/>
              </svg>
            </button>
            <div class="flex items-center gap-2 text-sm text-fg-muted">
              <span>首页</span>
              <span class="text-fg-dimmed">/</span>
              <span class="text-fg font-medium">{title}</span>
            </div>
          </div>

          <div class="flex items-center gap-4">
            <button class="w-9 h-9 flex items-center justify-center bg-transparent border-none rounded-sm text-fg-muted hover:bg-surface-alt hover:text-fg cursor-pointer transition-all duration-150 relative">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M18 8A6 6 0 0 0 6 8c0 7-3 9-3 9h18s-3-2-3-9"/><path d="M13.73 21a2 2 0 0 1-3.46 0"/>
              </svg>
            </button>
            <div class="w-[34px] h-[34px] rounded-full bg-accent text-white flex items-center justify-center text-sm font-semibold">
              管
            </div>
          </div>
        </header>

        <!-- Content -->
        <div class="flex-1 overflow-y-auto p-6">
          <slot />
        </div>
      </main>
    </div>

    <script>
      // ---- Sidebar toggle ----
      const sidebar = document.getElementById("sidebar");
      const toggleBtn = document.getElementById("sidebar-toggle");
      const sidebarW = 260;
      const sidebarCollapsed = 64;

      if (sidebar && toggleBtn) {
        const saved = localStorage.getItem("admin_sidebar_collapsed");
        if (saved === "true") {
          sidebar.style.width = sidebarCollapsed + "px";
          sidebar.style.minWidth = sidebarCollapsed + "px";
        }

        toggleBtn.addEventListener("click", () => {
          const isCollapsed = sidebar.style.width === sidebarCollapsed + "px" || sidebar.style.minWidth === sidebarCollapsed + "px";
          if (isCollapsed) {
            sidebar.style.width = sidebarW + "px";
            sidebar.style.minWidth = sidebarW + "px";
            localStorage.setItem("admin_sidebar_collapsed", "false");
          } else {
            sidebar.style.width = sidebarCollapsed + "px";
            sidebar.style.minWidth = sidebarCollapsed + "px";
            localStorage.setItem("admin_sidebar_collapsed", "true");
          }
        });
      }
    </script>
  </body>
</html>
