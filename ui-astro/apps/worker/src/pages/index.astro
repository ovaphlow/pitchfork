---
import MobileLayout from "../layouts/MobileLayout.astro";
---

<MobileLayout title="员工端">
  <div class="flex flex-col items-center justify-center py-20 text-center">
    <span class="text-5xl mb-4">🏭</span>
    <h2 class="text-lg font-semibold text-fg-emphasis mb-2">欢迎使用员工端</h2>
    <p class="text-sm text-fg-dimmed mb-6">知识搜索 · 扫码查看 · 在线培训</p>
    <a href="/search" class="inline-flex items-center justify-center h-10 px-6 rounded-md bg-accent text-white text-sm font-medium no-underline transition-all hover:brightness-110">
      开始使用
    </a>
  </div>
</MobileLayout>
