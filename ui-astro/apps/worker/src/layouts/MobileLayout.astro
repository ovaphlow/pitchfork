---
import "../styles/global.css";

interface Props {
  title: string;
  active?: "search" | "scan" | "training" | "skills" | "profile";
}

const { title, active } = Astro.props;

function isActive(name: string) {
  return active === name;
}
---

<!doctype html>
<html lang="zh-CN" class="dark">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover" />
    <title>{title} — 员工端</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  </head>
  <body class="bg-bg text-fg antialiased font-body">
    <div class="flex flex-col min-h-screen max-w-lg mx-auto">
      <!-- Header -->
      <header class="sticky top-0 z-30 bg-surface border-b border-border px-4 h-14 flex items-center justify-between shrink-0">
        <div class="flex items-center gap-3">
          <span class="text-xl">🏭</span>
          <h1 class="text-base font-semibold text-fg-emphasis">{title}</h1>
        </div>
        <button class="w-9 h-9 flex items-center justify-center rounded-md text-fg-muted hover:bg-surface-alt hover:text-fg cursor-pointer border-none transition-all duration-150">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round">
            <path d="M18 8A6 6 0 0 0 6 8c0 7-3 9-3 9h18s-3-2-3-9"/>
            <path d="M13.73 21a2 2 0 0 1-3.46 0"/>
          </svg>
        </button>
      </header>

      <!-- Content -->
      <main class="flex-1 overflow-y-auto px-4 py-4">
        <slot />
      </main>

      <!-- Bottom Nav -->
      <nav class="sticky bottom-0 z-30 bg-surface border-t border-border pb-safe">
        <div class="flex items-center justify-around h-16 px-2">
          <a href="/search" class={"flex flex-col items-center justify-center gap-0.5 w-16 py-1 no-underline transition-colors duration-150 " + (isActive("search") ? "text-accent" : "text-fg-dimmed")}>
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round">
              <circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/>
            </svg>
            <span class="text-[10px] font-medium">搜索</span>
          </a>
          <a href="/scan" class={"flex flex-col items-center justify-center gap-0.5 w-16 py-1 no-underline transition-colors duration-150 " + (isActive("scan") ? "text-accent" : "text-fg-dimmed")}>
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round">
              <path d="M3 7V5a2 2 0 0 1 2-2h2"/><path d="M17 3h2a2 2 0 0 1 2 2v2"/><path d="M21 17v2a2 2 0 0 1-2 2h-2"/><path d="M7 21H5a2 2 0 0 1-2-2v-2"/>
            </svg>
            <span class="text-[10px] font-medium">扫码</span>
          </a>
          <a href="/training" class={"flex flex-col items-center justify-center gap-0.5 w-16 py-1 no-underline transition-colors duration-150 " + (isActive("training") ? "text-accent" : "text-fg-dimmed")}>
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round">
              <path d="M4 19.5A2.5 2.5 0 0 1 6.5 17H20"/><path d="M6.5 2H20v20H6.5A2.5 2.5 0 0 1 4 19.5v-15A2.5 2.5 0 0 1 6.5 2z"/>
            </svg>
            <span class="text-[10px] font-medium">培训</span>
          </a>
          <a href="/skills" class={"flex flex-col items-center justify-center gap-0.5 w-16 py-1 no-underline transition-colors duration-150 " + (isActive("skills") ? "text-accent" : "text-fg-dimmed")}>
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round">
              <path d="M12 20h9"/><path d="M16.5 3.5a2.121 2.121 0 0 1 3 3L7 19l-4 1 1-4L16.5 3.5z"/>
            </svg>
            <span class="text-[10px] font-medium">技能</span>
          </a>
          <a href="/profile" class={"flex flex-col items-center justify-center gap-0.5 w-16 py-1 no-underline transition-colors duration-150 " + (isActive("profile") ? "text-accent" : "text-fg-dimmed")}>
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round">
              <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/>
            </svg>
            <span class="text-[10px] font-medium">我的</span>
          </a>
        </div>
      </nav>
    </div>
  </body>
</html>
